# Environment Configuration for VPS Deployment
# Copy this file to /var/www/arbre-genealogique/server/.env and update the values

# Server Configuration
NODE_ENV=production
PORT=5000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/arbre_genealogique

# JWT Secret (change this to a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# CORS Configuration
CORS_ORIGIN=*

# Admin Account (created automatically)
ADMIN_EMAIL=bassirou2010@gmail.com
ADMIN_PASSWORD=Keep0ut@2026!
