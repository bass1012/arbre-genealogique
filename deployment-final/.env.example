# Configuration pour LWS.fr
PORT=3000
NODE_ENV=production

# Remplacez par votre URI MongoDB Atlas
MONGODB_URI=mongodb+srv://admin-arbre:VOTRE_MOT_DE_PASSE@arbre-genealogique.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Générez un secret sécurisé (32 caractères minimum)
JWT_SECRET=votre_secret_tres_securise_32_caracteres_minimum
JWT_EXPIRES_IN=30d

# Remplacez par votre domaine LWS
CLIENT_URL=https://votredomaine.lws.fr

# Configuration Cloudinary (remplacez par vos vraies valeurs)
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret
